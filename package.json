{
  "name": "omnius",
  "version": "0.1.0",
  "description": "DI7 — A terminal-based cybersecurity text adventure and aptitude assessment game",
  "type": "module",
  "bin": {
    "omnius": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.tsx",
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cybersecurity",
    "game",
    "terminal",
    "cli",
    "security",
    "training",
    "ctf",
    "di7",
    "omnius"
  ],
  "author": "Shiv Garge <shiv@gargestudio.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shivgarge/omnius"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "ansi-escapes": "^7.3.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-spinners": "^3.4.0",
    "cli-table3": "^0.6.5",
    "date-fns": "^4.1.0",
    "figlet": "^1.11.0",
    "immer": "^11.1.4",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "ora": "^8.2.0",
    "react": "^18.3.1",
    "uuid": "^13.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
